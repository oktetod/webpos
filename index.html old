<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Joko Absensi</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Babel untuk React -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel" data-type="module">
        import React, { useState, useEffect } from 'https://esm.sh/react@18.2.0';
        import { createRoot } from 'https://esm.sh/react-dom@18.2.0/client';
        import { Settings, Users, Plus, Save, Clock, CheckCircle, LayoutDashboard, Trash2, CalendarDays, Printer, X, AlertCircle, LogOut, Lock, User as UserIcon, ArrowLeft } from 'https://esm.sh/lucide-react@0.344.0';
        
        // Firebase Imports
        import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js';
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from 'https://www.gstatic.com/firebasejs/10.8.1/firebase-auth.js';
        import { getFirestore, collection, doc, setDoc, addDoc, onSnapshot, deleteDoc } from 'https://www.gstatic.com/firebasejs/10.8.1/firebase-firestore.js';

        // ==========================================
        // FIREBASE CONFIGURATION ANDA
        // ==========================================
        const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {
            apiKey: "AIzaSyA9aXzUB7rnwNEAe7XIWl1ym1PDSFevMhg",
            authDomain: "absen-2b38f.firebaseapp.com",
            projectId: "absen-2b38f",
            storageBucket: "absen-2b38f.firebasestorage.app",
            messagingSenderId: "696925605556",
            appId: "1:696925605556:web:7be8b9429cf58f5e4091e1"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        
        // Namespace untuk penyimpanan data Anda
        const myAppId = typeof __app_id !== 'undefined' ? __app_id : 'joko-absen-app';

        function App() {
            const [user, setUser] = useState(null);
            
            // State untuk Login Admin
            const [isAuthenticated, setIsAuthenticated] = useState(localStorage.getItem('joko_admin_logged_in') === 'true');
            const [showLoginForm, setShowLoginForm] = useState(false);
            const [loginUser, setLoginUser] = useState('');
            const [loginPass, setLoginPass] = useState('');
            const [loginError, setLoginError] = useState('');

            const [activeTab, setActiveTab] = useState('dashboard');
            const [employees, setEmployees] = useState([]);
            const [cycles, setCycles] = useState([]);
            const [selectedCycleId, setSelectedCycleId] = useState('');
            const [allAttendance, setAllAttendance] = useState({});
            const [localInputs, setLocalInputs] = useState({});
            const [viewWeek, setViewWeek] = useState(1); 
            const [showPrintHint, setShowPrintHint] = useState(false);
            const [newEmpName, setNewEmpName] = useState('');
            const [newCycleStart, setNewCycleStart] = useState('');

            // Auth
            useEffect(() => {
                const initAuth = async () => {
                    try {
                        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                            await signInWithCustomToken(auth, __initial_auth_token);
                        } else {
                            await signInAnonymously(auth);
                        }
                    } catch (err) {
                        console.error("Auth Error:", err);
                    }
                };
                initAuth();
                const unsubscribe = onAuthStateChanged(auth, setUser);
                return () => unsubscribe();
            }, []);

            // Fetch Data (Menggunakan jalur PUBLIK agar admin & karyawan melihat data yang sama)
            useEffect(() => {
                if (!user) return;
                
                // Fetch Karyawan
                const empRef = collection(db, 'artifacts', myAppId, 'public', 'data', 'employees');
                const unsubEmp = onSnapshot(empRef, (snapshot) => {
                    setEmployees(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
                });

                // Fetch Siklus
                const cycleRef = collection(db, 'artifacts', myAppId, 'public', 'data', 'cycles');
                const unsubCycle = onSnapshot(cycleRef, (snapshot) => {
                    const cycleData = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                    cycleData.sort((a, b) => new Date(b.startDate) - new Date(a.startDate));
                    setCycles(cycleData);
                    setSelectedCycleId(prev => (!prev && cycleData.length > 0) ? cycleData[0].id : prev);
                });

                // Fetch Absensi
                const attRef = collection(db, 'artifacts', myAppId, 'public', 'data', 'attendance');
                const unsubAtt = onSnapshot(attRef, (snapshot) => {
                    const data = {};
                    snapshot.forEach(doc => { data[doc.id] = doc.data(); });
                    setAllAttendance(data);
                });

                return () => { unsubEmp(); unsubCycle(); unsubAtt(); };
            }, [user]);

            useEffect(() => {
                const inputs = {};
                Object.keys(allAttendance).forEach(date => {
                    Object.keys(allAttendance[date]).forEach(empId => {
                        inputs[`${date}_${empId}`] = allAttendance[date][empId];
                    });
                });
                setLocalInputs(inputs);
            }, [allAttendance]);

            // Handlers (Aksi Database - Hanya dieksekusi jika Admin)
            const handleAddEmployee = async (e) => {
                e.preventDefault();
                if (!newEmpName.trim() || !user || !isAuthenticated) return;
                await addDoc(collection(db, 'artifacts', myAppId, 'public', 'data', 'employees'), { name: newEmpName, createdAt: new Date().toISOString() });
                setNewEmpName('');
            };

            const handleDeleteEmployee = async (empId) => {
                if(user && isAuthenticated) await deleteDoc(doc(db, 'artifacts', myAppId, 'public', 'data', 'employees', empId));
            };

            const handleCreateCycle = async (e) => {
                e.preventDefault();
                if (!newCycleStart || !user || !isAuthenticated) return;
                const start = new Date(newCycleStart);
                const end = new Date(start); end.setDate(end.getDate() + 13);
                const payDay = new Date(start); payDay.setDate(payDay.getDate() + 14);

                await addDoc(collection(db, 'artifacts', myAppId, 'public', 'data', 'cycles'), {
                    startDate: start.toISOString().split('T')[0],
                    endDate: end.toISOString().split('T')[0],
                    payDate: payDay.toISOString().split('T')[0],
                    createdAt: new Date().toISOString()
                });
                setNewCycleStart('');
            };

            const handleInputChange = (empId, date, val) => {
                if (!isAuthenticated) return;
                setLocalInputs(prev => ({ ...prev, [`${date}_${empId}`]: val }));
            };

            const handleInputBlur = async (empId, date) => {
                if (!user || !isAuthenticated) return;
                const val = parseFloat(localInputs[`${date}_${empId}`]);
                const attRef = doc(db, 'artifacts', myAppId, 'public', 'data', 'attendance', date);
                if (isNaN(val) || val === '') await setDoc(attRef, { [empId]: 0 }, { merge: true });
                else await setDoc(attRef, { [empId]: val }, { merge: true });
            };

            const handleKeyDown = (e, date, rowIndex) => {
                if (!isAuthenticated) return;
                if (e.key === 'Enter' || e.keyCode === 13) {
                    e.preventDefault(); 
                    const nextInput = document.getElementById(`input-${date}-${rowIndex + 1}`);
                    if (nextInput) { nextInput.focus(); nextInput.select(); } 
                    else e.target.blur();
                }
            };

            const getRowTotal = (empId, allDates) => {
                return allDates.reduce((total, date) => total + (parseFloat(allAttendance[date]?.[empId]) || 0), 0);
            };

            const getCycleDates = () => {
                const cycle = cycles.find(c => c.id === selectedCycleId);
                if (!cycle) return [];
                const dates = [];
                let curr = new Date(cycle.startDate);
                const end = new Date(cycle.endDate);
                while (curr <= end) { dates.push(curr.toISOString().split('T')[0]); curr.setDate(curr.getDate() + 1); }
                return dates;
            };

            const cycleDates = getCycleDates();
            const activeCycleObj = cycles.find(c => c.id === selectedCycleId);
            const isMultiWeek = cycleDates.length > 7;
            const displayedDates = isMultiWeek ? cycleDates.slice((viewWeek - 1) * 7, viewWeek * 7) : cycleDates;
            const showTotalColumn = !isMultiWeek || viewWeek === 2;

            const formatShortDate = (dateString) => {
                const date = new Date(dateString);
                const days = ['Min', 'Sen', 'Sel', 'Rab', 'Kam', 'Jum', 'Sab'];
                return { day: days[date.getDay()], date: date.getDate() };
            };

            const handleLogin = (e) => {
                e.preventDefault();
                if (loginUser.toLowerCase() === 'bayu' && loginPass === '008') {
                    setIsAuthenticated(true);
                    localStorage.setItem('joko_admin_logged_in', 'true');
                    setLoginError('');
                    setShowLoginForm(false);
                } else {
                    setLoginError('Username atau Password salah!');
                }
            };

            const handleLogout = () => {
                setIsAuthenticated(false);
                localStorage.removeItem('joko_admin_logged_in');
                setLoginUser('');
                setLoginPass('');
                setActiveTab('dashboard');
            };

            const handlePrint = () => {
                setShowPrintHint(true);
                try { window.print(); } catch (e) { console.error(e); }
                setTimeout(() => setShowPrintHint(false), 8000);
            };

            if (!user) return <div className="flex items-center justify-center h-screen bg-gray-50"><div className="text-lg font-medium text-blue-600 animate-pulse flex items-center gap-2"><Clock className="w-6 h-6 animate-spin" /> Memuat Sistem...</div></div>;

            // Layar Login Khusus Admin
            if (showLoginForm && !isAuthenticated) {
                return (
                    <div className="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 font-sans">
                        <div className="absolute top-4 left-4">
                            <button onClick={() => setShowLoginForm(false)} className="flex items-center gap-2 text-gray-500 hover:text-gray-800 font-medium">
                                <ArrowLeft className="w-5 h-5" /> Kembali
                            </button>
                        </div>
                        <div className="sm:mx-auto sm:w-full sm:max-w-md mt-8">
                            <div className="flex justify-center">
                                <div className="bg-gradient-to-br from-blue-600 to-indigo-700 p-4 rounded-2xl text-white shadow-lg">
                                    <Lock className="w-10 h-10" />
                                </div>
                            </div>
                            <h2 className="mt-6 text-center text-3xl font-extrabold text-gray-900 tracking-tight">Login <span className="text-blue-600">Admin</span></h2>
                            <p className="mt-2 text-center text-sm text-gray-600">Masukkan kredensial untuk mengedit absensi</p>
                        </div>

                        <div className="mt-8 sm:mx-auto sm:w-full sm:max-w-md px-4 sm:px-0">
                            <div className="bg-white py-8 px-6 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.1)] sm:rounded-2xl sm:px-10 border border-gray-100">
                                <form className="space-y-6" onSubmit={handleLogin}>
                                    {loginError && (
                                        <div className="bg-red-50 border-l-4 border-red-500 p-4 rounded-md flex items-start gap-3 animate-in fade-in slide-in-from-top-2">
                                            <AlertCircle className="w-5 h-5 text-red-500 flex-shrink-0" />
                                            <p className="text-sm text-red-700 font-medium">{loginError}</p>
                                        </div>
                                    )}
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-1.5">Username</label>
                                        <div className="relative rounded-md shadow-sm">
                                            <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                <UserIcon className="h-5 w-5 text-gray-400" />
                                            </div>
                                            <input type="text" required value={loginUser} onChange={(e) => setLoginUser(e.target.value)} className="focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white block w-full pl-10 sm:text-sm border-gray-200 rounded-xl py-3 bg-gray-50 border outline-none transition-all font-medium text-gray-800" placeholder="Ketik username..." />
                                        </div>
                                    </div>

                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-1.5">Password</label>
                                        <div className="relative rounded-md shadow-sm">
                                            <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                <Lock className="h-5 w-5 text-gray-400" />
                                            </div>
                                            <input type="password" required value={loginPass} onChange={(e) => setLoginPass(e.target.value)} className="focus:ring-2 focus:ring-blue-500 focus:border-blue-500 focus:bg-white block w-full pl-10 sm:text-sm border-gray-200 rounded-xl py-3 bg-gray-50 border outline-none transition-all font-medium text-gray-800" placeholder="Ketik password..." />
                                        </div>
                                    </div>

                                    <div>
                                        <button type="submit" className="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-md text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all mt-2">
                                            Masuk
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                );
            }

            return (
                <div className="min-h-screen bg-gray-50 font-sans pb-12 text-gray-800">
                  <style>{`
                    @media print {
                      @page { size: portrait; margin: 5mm; } 
                      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; background: white !important; margin: 0; padding: 0; font-family: Arial, sans-serif; }
                      .no-print { display: none !important; } 
                      .print-only { display: block !important; width: 100%; } 
                      .print-table { width: 100%; table-layout: fixed; border-collapse: collapse; }
                      .print-table th, .print-table td { border: 1px solid #000 !important; padding: 3px 1px !important; font-size: 8px !important; color: #000 !important; word-wrap: break-word; text-align: center; }
                      .print-table th.col-no { width: 4%; }
                      .print-table th.col-name { width: 16%; text-align: left; padding-left: 4px !important; font-size: 9px !important; }
                      .print-table th.col-day { width: 5%; } 
                      .print-table th.col-total { width: 10%; font-size: 9px !important; font-weight: bold; }
                    }
                    .print-only { display: none; }
                    input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
                    input[type=number] { -moz-appearance: textfield; }
                  `}</style>

                  {/* Header Dashboard Publik */}
                  <header className="no-print bg-white shadow-[0_2px_10px_-3px_rgba(6,81,237,0.1)] sticky top-0 z-50">
                    <div className="max-w-7xl mx-auto px-3 sm:px-6 h-16 flex items-center justify-between">
                      <div className="flex items-center gap-2">
                        <div className="bg-gradient-to-br from-blue-600 to-indigo-700 p-2 rounded-xl text-white shadow-md"><CalendarDays className="w-5 h-5" /></div>
                        <h1 className="text-lg font-extrabold text-gray-800 hidden sm:block tracking-tight">Joko<span className="text-blue-600">Absensi</span></h1>
                      </div>
                      <div className="flex items-center gap-3">
                        <div className="flex space-x-1 sm:space-x-2 bg-gray-100 p-1.5 rounded-2xl">
                          <button onClick={() => setActiveTab('dashboard')} className={`flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] sm:text-sm font-semibold transition-all duration-200 ${activeTab === 'dashboard' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500'}`}><LayoutDashboard className="w-3.5 h-3.5" /> Absen</button>
                          
                          {/* Menu Karyawan & Siklus HANYA MUNCUL JIKA ADMIN LOGIN */}
                          {isAuthenticated && <button onClick={() => setActiveTab('karyawan')} className={`flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] sm:text-sm font-semibold transition-all duration-200 ${activeTab === 'karyawan' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500'}`}><Users className="w-3.5 h-3.5" /> Karyawan</button>}
                          {isAuthenticated && <button onClick={() => setActiveTab('siklus')} className={`flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[11px] sm:text-sm font-semibold transition-all duration-200 ${activeTab === 'siklus' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-500'}`}><Settings className="w-3.5 h-3.5" /> Siklus</button>}
                        </div>

                        {/* Tombol Akses (Login/Logout) */}
                        {isAuthenticated ? (
                          <button onClick={handleLogout} className="bg-red-50 text-red-600 p-2 rounded-xl hover:bg-red-100 transition-colors shadow-sm" title="Keluar">
                            <LogOut className="w-4 h-4 sm:w-5 sm:h-5" />
                          </button>
                        ) : (
                          <button onClick={() => setShowLoginForm(true)} className="bg-blue-50 text-blue-600 px-3 py-1.5 rounded-xl hover:bg-blue-100 transition-colors shadow-sm text-xs sm:text-sm font-bold flex items-center gap-1.5">
                            <Lock className="w-3.5 h-3.5" /> Admin
                          </button>
                        )}
                      </div>
                    </div>
                  </header>

                  <main className="no-print max-w-7xl mx-auto px-3 py-6">
                    {/* DASHBOARD */}
                    {activeTab === 'dashboard' && (
                      <div className="bg-white rounded-2xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] border border-gray-100 overflow-hidden">
                        
                        {!isAuthenticated && (
                          <div className="bg-blue-50 p-3 text-center text-sm font-medium text-blue-800 border-b border-blue-100 flex justify-center items-center gap-2">
                            <AlertCircle className="w-4 h-4" /> Mode Akses Publik (Hanya Baca)
                          </div>
                        )}

                        <div className="p-4 sm:p-5 bg-white border-b border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-4">
                          <select value={selectedCycleId} onChange={(e) => { setSelectedCycleId(e.target.value); setViewWeek(1); }} className="w-full sm:w-64 border border-gray-200 rounded-xl px-3 py-2.5 text-sm font-bold text-gray-700 bg-gray-50 outline-none">
                            {cycles.length === 0 && <option value="">Belum ada siklus</option>}
                            {cycles.map(c => <option key={c.id} value={c.id}>Tgl {new Date(c.startDate).toLocaleDateString('id-ID', {day: 'numeric', month:'short'})} - {new Date(c.endDate).toLocaleDateString('id-ID', {day: 'numeric', month:'short'})}</option>)}
                          </select>
                          
                          <div className="flex w-full sm:w-auto gap-2">
                            {isMultiWeek && (
                              <div className="flex bg-gray-100 p-1.5 rounded-xl flex-1 sm:w-[220px]">
                                <button onClick={() => setViewWeek(1)} className={`flex-1 py-1.5 text-xs font-bold rounded-lg ${viewWeek === 1 ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500'}`}>Minggu 1</button>
                                <button onClick={() => setViewWeek(2)} className={`flex-1 py-1.5 text-xs font-bold rounded-lg ${viewWeek === 2 ? 'bg-white shadow-sm text-blue-600' : 'text-gray-500'}`}>Minggu 2</button>
                              </div>
                            )}
                            {isAuthenticated && (
                              <button onClick={handlePrint} disabled={cycleDates.length === 0} className="bg-indigo-600 text-white px-3 py-1.5 rounded-xl text-xs font-bold shadow-md flex items-center gap-2"><Printer className="w-4 h-4" /> <span className="hidden sm:inline">Cetak</span></button>
                            )}
                          </div>
                        </div>

                        {employees.length === 0 ? <div className="p-12 text-center text-gray-500 text-sm">Belum ada karyawan.</div> : cycleDates.length === 0 ? <div className="p-12 text-center text-gray-500 text-sm">Belum ada siklus aktif.</div> : (
                          <div className="w-full">
                            <table className="w-full text-xs text-left border-collapse table-fixed">
                              <thead className="bg-gray-50 text-gray-600">
                                <tr>
                                  <th className="px-2 py-3 border-b border-r border-gray-200 font-bold w-[75px] align-bottom bg-white"><div className="text-[10px] text-gray-400 uppercase">Karyawan</div></th>
                                  {displayedDates.map((date) => {
                                    const { day, date: dateNum } = formatShortDate(date);
                                    return (
                                      <th key={date} className={`border-b border-r border-gray-200 text-center p-0 align-middle ${day === 'Min' ? 'bg-red-50' : 'bg-gray-50'}`}>
                                        <div className="text-[9px] uppercase font-semibold pt-2 opacity-80">{day}</div>
                                        <div className={`text-sm font-bold pb-2 ${day === 'Min' ? 'text-red-600' : 'text-gray-700'}`}>{dateNum}</div>
                                      </th>
                                    );
                                  })}
                                  {showTotalColumn && <th className="border-b border-l border-gray-200 font-extrabold text-center w-[40px] bg-blue-600 text-white align-middle"><div className="text-[9px] pt-2">TOT</div><div className="text-[10px] pb-2">Jam</div></th>}
                                </tr>
                              </thead>
                              <tbody>
                                {employees.map((emp, index) => (
                                  <tr key={emp.id} className="bg-white border-b border-gray-200">
                                    <td className="px-2 py-0 border-r border-gray-200 font-semibold text-gray-700 text-[11px] truncate h-11">{emp.name}</td>
                                    {displayedDates.map((date, dateIdx) => {
                                      const val = localInputs[`${date}_${emp.id}`];
                                      return (
                                        <td key={date} className="border-r border-gray-200 p-0 h-11 relative">
                                          {isAuthenticated ? (
                                            <input 
                                              id={`input-${date}-${index}`} type="number" min="0" step="0.5" tabIndex={(dateIdx * employees.length) + index + 1} enterKeyHint="next"
                                              value={val === undefined || val === 0 ? '' : val}
                                              onChange={(e) => handleInputChange(emp.id, date, e.target.value)}
                                              onBlur={() => handleInputBlur(emp.id, date)}
                                              onKeyDown={(e) => handleKeyDown(e, date, index)}
                                              className="w-full h-full absolute inset-0 text-center focus:bg-blue-100 bg-transparent text-gray-900 font-bold text-[13px] outline-none"
                                            />
                                          ) : (
                                            <div className="w-full h-full absolute inset-0 flex items-center justify-center text-gray-700 font-bold text-[13px]">
                                                {val || '-'}
                                            </div>
                                          )}
                                        </td>
                                      )
                                    })}
                                    {showTotalColumn && <td className="border-l-2 text-center font-extrabold text-blue-700 bg-blue-50/50 text-xs">{getRowTotal(emp.id, cycleDates) || '-'}</td>}
                                  </tr>
                                ))}
                              </tbody>
                            </table>
                          </div>
                        )}
                      </div>
                    )}

                    {/* KARYAWAN (KHUSUS ADMIN) */}
                    {activeTab === 'karyawan' && isAuthenticated && (
                      <div className="grid grid-cols-1 gap-4">
                        <div className="bg-white p-5 rounded-2xl shadow border border-gray-100">
                          <h2 className="text-base font-bold mb-4 flex items-center gap-2"><Users className="w-5 h-5"/> Tambah Karyawan</h2>
                          <form onSubmit={handleAddEmployee} className="flex gap-3">
                            <input type="text" value={newEmpName} onChange={(e) => setNewEmpName(e.target.value)} placeholder="Nama Lengkap..." className="flex-1 border rounded-xl px-4 py-2.5 text-sm outline-none bg-gray-50 focus:bg-white" />
                            <button type="submit" disabled={!newEmpName.trim()} className="bg-blue-600 text-white px-4 py-2.5 rounded-xl font-semibold">Simpan</button>
                          </form>
                        </div>
                        <div className="bg-white p-5 rounded-2xl shadow border border-gray-100">
                          <h2 className="text-base font-bold mb-4">Daftar Karyawan</h2>
                          <div className="space-y-2 max-h-[300px] overflow-y-auto">
                            {employees.map((emp) => (
                              <div key={emp.id} className="flex justify-between items-center p-3 border rounded-xl bg-gray-50">
                                <span className="font-semibold text-sm">{emp.name}</span>
                                <button onClick={() => handleDeleteEmployee(emp.id)} className="text-red-500 p-1.5"><Trash2 className="w-4 h-4" /></button>
                              </div>
                            ))}
                          </div>
                        </div>
                      </div>
                    )}

                    {/* SIKLUS (KHUSUS ADMIN) */}
                    {activeTab === 'siklus' && isAuthenticated && (
                      <div className="grid grid-cols-1 gap-4">
                        <div className="bg-white p-5 rounded-2xl shadow border border-gray-100">
                          <h2 className="text-base font-bold mb-2 flex items-center gap-2"><CalendarDays className="w-5 h-5"/> Buat Siklus Baru (14 Hari)</h2>
                          <form onSubmit={handleCreateCycle} className="space-y-4 mt-4">
                            <input type="date" value={newCycleStart} onChange={(e) => setNewCycleStart(e.target.value)} required className="w-full border rounded-xl px-4 py-2.5 text-sm outline-none bg-gray-50 focus:bg-white" />
                            <button type="submit" className="w-full bg-gray-800 text-white text-sm font-bold py-3 rounded-xl flex justify-center items-center gap-2"><Save className="w-4 h-4" /> Simpan & Aktifkan</button>
                          </form>
                        </div>
                        <div className="bg-white p-5 rounded-2xl shadow border border-gray-100">
                          <h2 className="text-base font-bold mb-4">Riwayat Siklus</h2>
                          <div className="space-y-3 max-h-[300px] overflow-y-auto">
                            {cycles.map((cycle) => (
                              <div key={cycle.id} className="p-4 border rounded-xl bg-gray-50">
                                <div className="text-sm font-bold">{new Date(cycle.startDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' })} s/d {new Date(cycle.endDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' })}</div>
                                <div className="text-xs font-semibold text-blue-600 mt-1">Jadwal Gaji: {new Date(cycle.payDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}</div>
                              </div>
                            ))}
                          </div>
                        </div>
                      </div>
                    )}
                  </main>

                  {/* Notifikasi Print */}
                  {showPrintHint && (
                    <div className="no-print fixed bottom-6 left-1/2 transform -translate-x-1/2 bg-slate-800 text-white p-4 rounded-2xl shadow-2xl z-[100] flex items-start gap-3 w-[90%] max-w-sm">
                      <div className="text-sm flex-1">
                        <p className="font-bold mb-1">Membuka fitur cetak...</p>
                        <p className="text-xs text-slate-300">Jika pop-up tidak muncul, klik ikon Titik Tiga (⋮) di browser ➔ Pilih Bagikan ➔ Pilih Cetak / Print.</p>
                      </div>
                    </div>
                  )}

                  {/* PRINT VIEW (KHUSUS ADMIN) */}
                  {cycleDates.length > 0 && activeCycleObj && isAuthenticated && (
                    <div className="print-only">
                      <div style={{ textAlign: 'center', marginBottom: '10px', borderBottom: '2px solid black', paddingBottom: '5px' }}>
                        <h1 style={{ fontSize: '14px', fontWeight: 'bold', textTransform: 'uppercase', margin: '0 0 2px 0' }}>Laporan Absensi Karyawan</h1>
                        <p style={{ fontSize: '10px', margin: 0 }}>Periode: {new Date(activeCycleObj.startDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })} s/d {new Date(activeCycleObj.endDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })}</p>
                      </div>
                      <table className="print-table">
                        <thead>
                          <tr>
                            <th className="col-no" style={{ backgroundColor: '#f3f4f6' }}>No</th>
                            <th className="col-name" style={{ backgroundColor: '#f3f4f6' }}>Nama Karyawan</th>
                            {cycleDates.map(date => {
                              const day = formatShortDate(date).day;
                              return (
                                <th key={`ph-${date}`} className="col-day" style={{ backgroundColor: day === 'Min' ? '#fee2e2' : '#f9fafb' }}>
                                  <div style={{ fontSize: '7px' }}>{day}</div>
                                  <div style={{ fontSize: '9px', fontWeight: 'bold' }}>{formatShortDate(date).date}</div>
                                </th>
                              );
                            })}
                            <th className="col-total" style={{ backgroundColor: '#e5e7eb' }}>Tot<br/>Jam</th>
                          </tr>
                        </thead>
                        <tbody>
                          {employees.map((emp, idx) => (
                            <tr key={`pr-${emp.id}`}>
                              <td>{idx + 1}</td>
                              <td style={{ fontWeight: 'bold', textAlign: 'left' }}>{emp.name}</td>
                              {cycleDates.map(date => (
                                <td key={`pc-${date}`} style={{ fontWeight: 'bold', backgroundColor: formatShortDate(date).day === 'Min' ? '#fef2f2' : 'transparent' }}>
                                  {localInputs[`${date}_${emp.id}`] || ''}
                                </td>
                              ))}
                              <td style={{ backgroundColor: '#f3f4f6', fontWeight: 'bold' }}>{getRowTotal(emp.id, cycleDates) || ''}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                      <div style={{ marginTop: '20px', display: 'flex', justifyContent: 'flex-end', paddingRight: '20px' }}>
                        <div style={{ textAlign: 'center' }}>
                          <p style={{ fontSize: '10px', marginBottom: '40px' }}>Disetujui Oleh,</p>
                          <p style={{ fontSize: '10px', fontWeight: 'bold', borderBottom: '1px solid black', padding: '0 20px', display: 'inline-block' }}>Pimpinan / Admin</p>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
            );
        }

        const root = createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>


